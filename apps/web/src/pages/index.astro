---
import Layout from '../layouts/Layout.astro'
import ImageCard from '../components/ImageCard.astro'
import MailButton from '../components/MailButton.astro'
---

<Layout title="Aglabs Dev" description="An innovative labs.">
  <main
    class="mx-auto flex w-full max-w-lg flex-col items-center justify-center space-y-8 px-4 py-8"
  >
    <div class="px-4">
      <ImageCard
        src="/logo-primary.svg"
        alt="Aglabs Dev"
        class="max-w-3xs rounded-full"
        fetchpriority="high"
      />
    </div>
    <h1 class="mt-8 text-center text-4xl font-bold">Aglabs Dev</h1>
    <MailButton />
  </main>
</Layout>
